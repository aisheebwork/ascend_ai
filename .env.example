# --- Frontend (Vite) — Firebase Web App config (PUBLIC, safe to ship) ---
# From Firebase Console > Project settings > Your apps > Web app SDK config.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Cloudflare Pages Function (SERVER-SIDE secrets — do NOT prefix with VITE_) ---
# Set these in Cloudflare Pages > Settings > Environment variables (and as secrets).
# GEMINI_API_KEY      : Google AI Studio API key for the Gemini REST API
# FIREBASE_PROJECT_ID : same project id as above; used to validate ID token iss/aud
GEMINI_API_KEY=
FIREBASE_PROJECT_ID=
